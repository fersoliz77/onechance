rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email.matches('.*admin.*');
    }

    function isPublished(resource) {
      return resource.data.status == 'published';
    }

    // Public profile collections — published profiles readable by anyone,
    // all profiles readable by admin and owner
    match /players/{userId} {
      allow read: if isPublished(resource) || isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /coaches/{userId} {
      allow read: if isPublished(resource) || isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /clubs/{userId} {
      allow read: if isPublished(resource) || isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /agents/{userId} {
      allow read: if isPublished(resource) || isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    // User records — owner reads their own, admin reads all
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
    }
  }
}
